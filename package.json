  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "scrape": "npx ts-node --esm scripts/scrape_big_board.ts && npx ts-node --esm scripts/scrape_consensus.ts",
